PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=crowdview
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
CLIENT_URL=https://crowdview.tv

# Face recognition provider: 'rekognition' (AWS) or 'compreface'
FACE_PROVIDER=compreface

# AWS Rekognition (used when FACE_PROVIDER=rekognition)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
REKOGNITION_COLLECTION_ID=crowdview-faces

# CompreFace (used when FACE_PROVIDER=compreface)
COMPREFACE_URL=http://localhost:8000
COMPREFACE_DETECT_KEY=
COMPREFACE_RECOGNIZE_KEY=

# MediaMTX streaming server
MEDIAMTX_API_URL=http://127.0.0.1:9997
RECORDINGS_ROOT=/var/www/crowdview-streams

# SMTP for password reset emails (leave blank to log reset URLs to console instead)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=yoursmtppassword
SMTP_FROM=noreply@crowdview.tv
